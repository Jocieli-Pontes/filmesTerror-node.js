<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Noticias</title>
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    <header>
        <p> Nocturna </p>
        <div class="cabecalho">
            <a href="/" class="link1">Home</a>
            <a href="noticias" class="link1">Noticias</a>
            <a href="favoritos" class="link1">Favoritos</a>
            <a href="perfil" class="link1">Perfil</a>
        </div>
    </header>
    <h1 class="titulo">🩸 Notícias de Filmes de Terror</h1>

<div class="container-noticias">
    <%noticia.forEach((noticias) =>{ %> 
        <div class="noticia">
        <h2><%=noticias.titulo%></h2>
        <p><%=noticias.corpo%></p>
        <button>Ler mais</button>
    </div>

    <% }) %>

    

</div>

<div class="voltar">
    <a href="/">Voltar para o catálogo</a>
</div>

</body>
</html>